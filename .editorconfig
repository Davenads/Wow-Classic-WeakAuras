root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yml,yaml,json}]
indent_size = 2

[*.txt]
# Export strings are single long lines — don't let the editor mangle them
trim_trailing_whitespace = false
insert_final_newline = false
